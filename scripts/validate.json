// scripts/validate.js
// Checks every file in domains/ is valid before it's allowed to merge.

const fs = require("fs");
const path = require("path");

const DOMAINS_DIR = path.join(__dirname, "..", "domains");
const BANNED = ["www", "mail"];
const VALID_TYPES = ["CNAME", "A", "AAAA", "TXT"];

let hasError = false;

function fail(file, message) {
  console.error(`❌ ${file}: ${message}`);
  hasError = true;
}

const files = fs.readdirSync(DOMAINS_DIR).filter(f => f.endsWith(".json") && f !== "_example.json");

const seenSubdomains = new Set();

for (const file of files) {
  const fullPath = path.join(DOMAINS_DIR, file);
  let data;

  try {
    data = JSON.parse(fs.readFileSync(fullPath, "utf8"));
  } catch (e) {
    fail(file, "Not valid JSON");
    continue;
  }

 
  if (!data.subdomain) fail(file, "Missing 'subdomain'");
  if (!data.owner || !data.owner.username) fail(file, "Missing 'owner.username'");
  if (!data.record || !data.record.type || !data.record.value) {
    fail(file, "Missing 'record.type' or 'record.value'");
    continue;
  }


  const expectedFilename = `${data.subdomain}.json`;
  if (file !== expectedFilename) {
    fail(file, `Filename must match subdomain — expected '${expectedFilename}'`);
  }

  if (!/^[a-z0-9-]+$/.test(data.subdomain)) {
    fail(file, "Subdomain must be lowercase letters, numbers, and hyphens only");
  }


  if (BANNED.includes(data.subdomain.toLowerCase())) {
    fail(file, `'${data.subdomain}' is a reserved subdomain and can't be claimed`);
  }

  if (seenSubdomains.has(data.subdomain)) {
    fail(file, `Duplicate subdomain '${data.subdomain}'`);
  }
  seenSubdomains.add(data.subdomain);


  if (!VALID_TYPES.includes(data.record.type)) {
    fail(file, `record.type must be one of: ${VALID_TYPES.join(", ")}`);
  }
}

if (hasError) {
  console.error("\nValidation failed. Fix the errors above and push again.");
  process.exit(1);
} else {
  console.log(`✅ All ${files.length} domain file(s) valid.`);
}
